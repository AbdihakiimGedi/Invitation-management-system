# Docker Compose production values
# Quote this value in shell environments because it contains spaces.
POSTGRES_DB="Digital Invitation & Attendance Management"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_a_strong_database_password
POSTGRES_VOLUME_NAME=digital_invitation_postgres_data

# Backend accepts either DB_* or PG* variables. Keep these pointed at the
# postgres compose service unless you intentionally use an external database.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace_with_a_strong_database_password
DB_NAME="Digital Invitation & Attendance Management"
PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=replace_with_a_strong_database_password
PGDATABASE="Digital Invitation & Attendance Management"

# Backend runtime
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=8h
CORS_ORIGIN=https://your-frontend-domain.example
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_BYTES=5242880

# Host port mappings for direct VPS deployment.
# Coolify usually routes to the container internally, so these can be omitted there.
BACKEND_PUBLIC_PORT=5001
FRONTEND_PUBLIC_PORT=8080

# Browser/mobile-facing API URL
VITE_API_BASE_URL=https://your-backend-domain.example/api/v1
EXPO_PUBLIC_API_BASE_URL=https://your-backend-domain.example
